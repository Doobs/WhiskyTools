@using WhiskyTools.Models
@inject IJSRuntime JS

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Whisky Dilution Calculator</h4>
    <button class="btn btn-outline-secondary btn-sm" @onclick="OpenSettings" title="Preset settings">
        ⚙️
    </button>
</div>

<div class="mb-3 row">
    <label class="col-sm-3 col-form-label">Volume (ml):</label>
    <div class="col-sm-9 mt-2">
        <div class="input-group">
            <input type="number" class="form-control" @bind="volume" />
            @foreach (var preset in volumePresets)
            {
                <button class="btn btn-outline-secondary" @onclick="() => SetVolume(preset)">@preset.ToString("0")</button>
            }
        </div>
    </div>
</div>

<div class="mb-3 row">
    <label class="col-sm-3 col-form-label">Current ABV (%):</label>
    <div class="col-sm-9 mt-2">
        <input type="number" class="form-control" @bind="currentAbv" />
    </div>
</div>

<div class="mb-3 row">
    <label class="col-sm-3 col-form-label">Target ABV (%):</label>
    <div class="col-sm-9 mt-2">
        <div class="input-group">
            <input type="number" class="form-control" @bind="targetAbv" />
            @foreach (var preset in targetAbvPresets)
            {
                <button class="btn btn-outline-secondary" @onclick="() => SetTarget(preset)">@preset.ToString("0")</button>
            }
        </div>
    </div>
</div>

<button class="btn btn-primary" @onclick="CalculateDilution">Calculate</button>

@if (waterToAdd > 0)
{
    <p class="mt-3">Add <b>@waterToAdd.ToString("F1") ml</b> of water.</p>
}

@if (showSettings)
{
    <PresetSettings Settings="settings" OnSettingsChanged="HandleSettingsChanged" OnClose="CloseSettings" />
}

@code {
    double volume = 30;
    double currentAbv = 57.2;
    double targetAbv = 43;
    double waterToAdd;

    private bool showSettings;
    private WhiskyPresetSettings settings = new()
    {
        VolumePresets = new List<double> { 30, 50 },
        TargetAbvPresets = new List<double> { 40, 43, 46 }
    };

    private List<double> volumePresets = new() { 30, 50 };
    private List<double> targetAbvPresets = new() { 40, 43, 46 };

    protected override async Task OnInitializedAsync()
    {
        await LoadSettings();
        CalculateDilution();
    }

    private async Task LoadSettings()
    {
        var stored = await JS.InvokeAsync<string?>("localStorage.getItem", "whiskytools.presetSettings");
        if (!string.IsNullOrWhiteSpace(stored))
        {
            try
            {
                var parsed = System.Text.Json.JsonSerializer.Deserialize<WhiskyPresetSettings>(stored);
                if (parsed is not null)
                {
                    settings = parsed;
                    volumePresets = parsed.VolumePresets.Any() ? parsed.VolumePresets : new List<double> { 30, 50 };
                    targetAbvPresets = parsed.TargetAbvPresets.Any() ? parsed.TargetAbvPresets : new List<double> { 40, 43, 46 };
                }
            }
            catch
            {
                // Ignore malformed storage and fall back to defaults.
            }
        }
    }

    private void OpenSettings()
    {
        showSettings = true;
    }

    private void CloseSettings()
    {
        showSettings = false;
    }

    private async Task HandleSettingsChanged(WhiskyPresetSettings updatedSettings)
    {
        settings = updatedSettings;
        volumePresets = updatedSettings.VolumePresets.Any() ? updatedSettings.VolumePresets : new List<double> { 30, 50 };
        targetAbvPresets = updatedSettings.TargetAbvPresets.Any() ? updatedSettings.TargetAbvPresets : new List<double> { 40, 43, 46 };
        await Task.CompletedTask;
    }

    void CalculateDilution()
    {
        var finalVolume = (currentAbv * volume) / targetAbv;
        waterToAdd = finalVolume - volume;
    }

    void SetVolume(double preset)
    {
        volume = preset;
        CalculateDilution();
    }

    void SetTarget(double target)
    {
        targetAbv = target;
        CalculateDilution();
    }
}
